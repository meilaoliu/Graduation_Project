<launch>
  <arg name="map_size_x_"/>
  <arg name="map_size_y_"/>
  <arg name="map_size_z_"/>

  <arg name="odometry_topic"/>
  <arg name="goal_topic"/>
  <arg name="camera_pose_topic"/>
  <arg name="depth_topic"/>
  <arg name="cloud_topic"/>

  <arg name="cx"/>
  <arg name="cy"/>
  <arg name="fx"/>
  <arg name="fy"/>

  <arg name="max_vel"/>
  <arg name="max_acc"/>
  <arg name="max_jer"/>
  <!-- maximum angular velocity, curvature and angular velocity -->
  <arg name="max_w"/>
  <arg name="max_k"/>
  <arg name="max_k_inflation"/>


  <arg name="planning_horizon"/>

  <arg name="point_num"/>
  <arg name="point0_x"/>
  <arg name="point0_y"/>
  <arg name="point0_z"/>
  <arg name="point1_x"/>
  <arg name="point1_y"/>
  <arg name="point1_z"/>
  <arg name="point2_x"/>
  <arg name="point2_y"/>
  <arg name="point2_z"/>
  <arg name="point3_x"/>
  <arg name="point3_y"/>
  <arg name="point3_z"/>
  <arg name="point4_x"/>
  <arg name="point4_y"/>
  <arg name="point4_z"/>

  <arg name="point5_x"/>
  <arg name="point5_y"/>
  <arg name="point5_z"/>
  <arg name="point6_x"/>
  <arg name="point6_y"/>
  <arg name="point6_z"/>

  <arg name="flight_type"/>

  <!-- main node -->
  <node pkg="ego_planner" name="ego_planner_node" type="ego_planner_node" output="screen">
    <remap from="/odom_map" to="$(arg odometry_topic)"/>
    <remap from="/way_point" to="$(arg goal_topic)"/>
    <remap from="/grid_map/odom" to="$(arg odometry_topic)"/>
    <remap from="/grid_map/cloud" to="$(arg cloud_topic)"/>
    <remap from = "/grid_map/pose"   to = "$(arg camera_pose_topic)"/> 
    <remap from = "/grid_map/depth" to = "$(arg depth_topic)"/>

    <!-- planning fsm -->
    <param name="fsm/flight_type" value="$(arg flight_type)" type="int"/>
    <param name="fsm/thresh_replan" value="2.5" type="double"/>
    <param name="fsm/thresh_no_replan" value="2.0" type="double"/>
    <param name="fsm/planning_horizon" value="$(arg planning_horizon)" type="double"/> <!--always set to 1.5 times grater than sensing horizen-->
    <param name="fsm/planning_horizen_time" value="2.0" type="double"/>
    <param name="fsm/emergency_time_" value="1.0" type="double"/>
    <!-- w_adjust :掉头速度 -->
    <param name="fsm/w_adjust_" value="1.0" type="double"/>
    <!-- forward_only: true=只允许前进(需要原地掉头), false=允许倒车 -->
    <param name="fsm/forward_only" value="false" type="bool"/>

    <param name="fsm/waypoint_num" value="$(arg point_num)" type="int"/>
    <param name="fsm/waypoint0_x" value="$(arg point0_x)" type="double"/>
    <param name="fsm/waypoint0_y" value="$(arg point0_y)" type="double"/>
    <param name="fsm/waypoint0_z" value="$(arg point0_z)" type="double"/>
    <param name="fsm/waypoint1_x" value="$(arg point1_x)" type="double"/>
    <param name="fsm/waypoint1_y" value="$(arg point1_y)" type="double"/>
    <param name="fsm/waypoint1_z" value="$(arg point1_z)" type="double"/>
    <param name="fsm/waypoint2_x" value="$(arg point2_x)" type="double"/>
    <param name="fsm/waypoint2_y" value="$(arg point2_y)" type="double"/>
    <param name="fsm/waypoint2_z" value="$(arg point2_z)" type="double"/>
    <param name="fsm/waypoint3_x" value="$(arg point3_x)" type="double"/>
    <param name="fsm/waypoint3_y" value="$(arg point3_y)" type="double"/>
    <param name="fsm/waypoint3_z" value="$(arg point3_z)" type="double"/>
    <param name="fsm/waypoint4_x" value="$(arg point4_x)" type="double"/>
    <param name="fsm/waypoint4_y" value="$(arg point4_y)" type="double"/>
    <param name="fsm/waypoint4_z" value="$(arg point4_z)" type="double"/>

    <param name="fsm/waypoint5_x" value="$(arg point5_x)" type="double"/>
    <param name="fsm/waypoint5_y" value="$(arg point5_y)" type="double"/>
    <param name="fsm/waypoint5_z" value="$(arg point5_z)" type="double"/>
    <param name="fsm/waypoint6_x" value="$(arg point6_x)" type="double"/>
    <param name="fsm/waypoint6_y" value="$(arg point6_y)" type="double"/>
    <param name="fsm/waypoint6_z" value="$(arg point6_z)" type="double"/>

    <param name="grid_map/resolution"      value="0.1" />
    <param name="grid_map/map_size_x"   value="$(arg map_size_x_)" />
    <param name="grid_map/map_size_y"   value="$(arg map_size_y_)" />
    <param name="grid_map/map_size_z"   value="$(arg map_size_z_)" />
    <param name="grid_map/local_update_range_x"  value="8.0" />
    <param name="grid_map/local_update_range_y"  value="8.0" />
    <param name="grid_map/local_update_range_z"  value="1.5" />
    <!--障碍物膨胀层-->
    <param name="grid_map/obstacles_inflation"     value="0.4" />
    <param name="grid_map/segmentation_2d_p_hit" value="0.65" />
    <param name="grid_map/segmentation_2d_p_miss" value="0.48" />
    <param name="grid_map/segmentation_2d_p_occ" value="0.80" />
    <param name="grid_map/local_map_margin" value="2"/>
    <param name="grid_map/ground_height"        value="-0.01"/>
    <!-- camera parameter -->
    <param name="grid_map/cx" value="$(arg cx)"/>
    <param name="grid_map/cy" value="$(arg cy)"/>
    <param name="grid_map/fx" value="$(arg fx)"/>
    <param name="grid_map/fy" value="$(arg fy)"/>
    <!-- depth filter -->
    <param name="grid_map/use_depth_filter" value="true"/>
    <param name="grid_map/depth_filter_tolerance" value="0.15"/>
    <param name="grid_map/depth_filter_maxdist"   value="5.0"/>
    <param name="grid_map/depth_filter_mindist"   value="0.2"/>
    <param name="grid_map/depth_filter_margin"    value="1"/>
    <param name="grid_map/k_depth_scaling_factor" value="1000.0"/>
    <param name="grid_map/skip_pixel" value="2"/>
    <!-- local fusion -->
    <param name="grid_map/p_hit"  value="0.65"/>
    <param name="grid_map/p_miss" value="0.35"/>
    <param name="grid_map/p_min"  value="0.12"/>
    <param name="grid_map/p_max"  value="0.90"/>
    <param name="grid_map/p_occ"  value="0.80"/>
    <param name="grid_map/min_ray_length" value="0.1"/>
    <param name="grid_map/max_ray_length" value="8.0"/>

    <param name="grid_map/virtual_ceil_height"   value="2.5"/>
    <param name="grid_map/visualization_truncate_height"   value="1.6"/>
    <param name="grid_map/show_occ_time"  value="false"/>
    <param name="grid_map/pose_type"     value="2"/>
    <param name="grid_map/map_type"     value="1"/>
    <param name="grid_map/frame_id"      value="map"/>

  <!-- planner manager -->
    <!--use_minco：true = 使用minco轨迹，false = 使用B样条轨迹-->
    <param name="manager/use_minco" value="true" type="bool"/>
    <param name="manager/max_vel" value="$(arg max_vel)" type="double"/>
    <param name="manager/max_acc" value="$(arg max_acc)" type="double"/>
    <param name="manager/max_w" value="$(arg max_w)" type="double"/>
    <param name="manager/control_points_distance" value="0.6" type="double"/>
    <param name="manager/polyTraj_piece_length" value="1.5" type="double"/>
    <param name="manager/feasibility_tolerance" value="0.05" type="double"/>
    <param name="manager/planning_horizon" value="$(arg planning_horizon)" type="double"/>
    <!--是否开启拓扑同伦轨迹（会增加计算量）-->
    <param name="manager/use_multitopology_trajs" value="false" type="bool"/>

  <!-- Bspline trajectory optimization -->
    <param name="optimization/lambda_smooth" value="1.0" type="double"/>
    <param name="optimization/lambda_collision" value="0.8" type="double"/>
    <param name="optimization/lambda_feasibility" value="1.5" type="double"/>
    <param name="optimization/lambda_fitness" value="1.0" type="double"/>
    <param name="optimization/dist0" value="1.0" type="double"/>
    <param name="optimization/max_vel" value="$(arg max_vel)" type="double"/>
    <param name="optimization/max_acc" value="$(arg max_acc)" type="double"/>
    <param name="optimization/max_w" value="$(arg max_w)" type = "double"/>
    <param name="optimization/max_k" value="$(arg max_k)" type = "double"/>
    <param name="optimization/max_k_inflation" value="$(arg max_k_inflation)" type="double"/>
    
    <param name="bspline/limit_vel" value="$(arg max_vel)" type="double"/>
    <param name="bspline/limit_acc" value="$(arg max_acc)" type="double"/>
    <param name="bspline/limit_ratio" value="1.1" type="double"/>

    <!-- MINCO optimization parameters (H2 阶段验证最优组合, 成功率最高) -->
    <!-- 修复 C: 10 × 5 段 = 50 采样点代价过重且让 LBFGS 不易收敛; 7 间距 0.21m 仍<0.5m膨胀
         满足采样不漏障碍的需求, 同时控制 LBFGS 单次代价 -->
    <param name="optimization/constraint_points_perPiece" value="6" type="int"/>
    <!-- 修复 (穿障): 1500 时仍有 SAFETY 期间 Replan 抢救, 上调到 2500 强约束 -->
    <param name="optimization/weight_obstacle" value="1000.0" type="double"/>
    <param name="optimization/weight_obstacle_soft" value="1000.0" type="double"/>
    <param name="optimization/weight_feasibility" value="1500.0" type="double"/>
    <!-- 修复 D: weight_curv 500 让代价面过陡, 初值偏差就炸 → 中间值 250 -->
    <param name="optimization/weight_curv" value="100.0" type="double"/>
    <param name="optimization/weight_sqrvariance" value="1000.0" type="double"/>
    <!-- atan 软饱和 (Fix H2) 已限制 RT≤431, 可以放心调到 450 -->
    <param name="optimization/weight_time" value="300.0" type="double"/>
    <!-- 修复 (穿障): clearance 过小时 cost 梯度太弱, 0.13 → 0.18 抬高安全余量 -->
    <param name="optimization/obstacle_clearance" value="0.15" type="double"/>
    <param name="optimization/obstacle_clearance_soft" value="0.25" type="double"/>
    <param name="optimization/max_curv" value="$(arg max_k)" type="double"/>
    
    <!-- MPC 控制器参数 -->
    <param name="MPC/v_max" value="$(arg max_vel)" type="double"/>
    <param name="MPC/w_max" value="$(arg max_w)" type="double"/>
    <!-- 解耦权重: Q = diag(w_pos, w_pos, w_ang), 终端放大 rho_N -->
    <!-- w_ang=5.0 偏高: 小角度误差被放大成大 ω → 实车滑出曲线 → 下一帧起点 v/a 错配 -->
    <param name="MPC/w_pos" value="1.0" type="double"/>
    <param name="MPC/w_ang" value="3.0" type="double"/>
    <param name="MPC/rho_N" value="5.0" type="double"/>
    <!-- 输入权重: R = diag(r_v, r_w) -->
    <param name="MPC/r_v" value="0.1" type="double"/>
    <param name="MPC/r_w" value="0.1" type="double"/>
    <!-- 前馈参考输入开关 (消融实验用) -->
    <param name="MPC/use_feedforward" value="true" type="bool"/>
    <!-- 延时补偿 -->
    <param name="MPC/use_delay_compensation" value="true" type="bool"/>
    <param name="MPC/delay_ms" value="50.0" type="double"/>

  </node>



</launch>

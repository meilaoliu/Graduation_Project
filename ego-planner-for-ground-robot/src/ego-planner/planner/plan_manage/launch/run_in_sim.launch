<launch>
  <!-- size of map, change the size inflate x, y, z according to your application -->
  <arg name="map_size_x" value="50"/>
  <arg name="map_size_y" value="50"/>
  <arg name="map_size_z" value=" 4.0"/>

  <!-- topic of your odometry such as VIO or LIO -->
  <arg name="odom_topic" value="/state_estimation" />
  <arg name="pointcloud_topic" value="/registered_scan" />
  
  <arg name="use_rqt_robot_steering" value="true" />
  
  <!-- main algorithm params -->
  <include file="$(find ego_planner)/launch/advanced_param.xml">

    <arg name="map_size_x_" value="$(arg map_size_x)"/>
    <arg name="map_size_y_" value="$(arg map_size_y)"/>
    <arg name="map_size_z_" value="$(arg map_size_z)"/>
    <arg name="odometry_topic" value="$(arg odom_topic)"/>

    <!-- camera pose: transform of camera frame in the world frame -->
    <!-- depth topic: depth image, 640x480 by default -->
    <!-- don't set cloud_topic if you already set these ones! -->
    <arg name="camera_pose_topic" value="/pcl_render_node/camera_pose"/>
    <arg name="depth_topic" value="/pcl_render_node/depth"/>

    <!-- topic of point cloud measurement, such as from LIDAR  -->
    <!-- don't set camera pose and depth, if you already set this one! -->
    <arg name="cloud_topic" value="$(arg pointcloud_topic)"/>
    <arg name="goal_topic" value="/move_base_simple/goal"/>

    <!-- intrinsic params of the depth camera -->

    <arg name="cx" value="321.04638671875"/>
    <arg name="cy" value="243.44969177246094"/>
    <arg name="fx" value="387.229248046875"/>
    <arg name="fy" value="387.229248046875"/>

    <!-- maximum velocity and acceleration the drone will reach -->
    <arg name="max_vel" value="1.3" />
    <arg name="max_acc" value="2" />
    <arg name="max_jer" value="5.0" />
    <!-- maximum angular velocity, curvature and angular velocity -->
    <!-- 差速运动学约束: ω = v·κ, 取 max_k ≤ max_w/max_vel = 2.0/1.3 ≈ 1.54 避免约束自相矛盾 -->
    <arg name="max_w" value="2.0" />
    <arg name="max_k" value="2.0" />
    <!--fotr B-spline-->
    <arg name="max_k_inflation" value="8.0" /> 

    <!--always set to 1.5 times grater than sensing horizen-->
    <!-- 7.5 在密集障碍区让 local target 太远, BVP 时间分配过长触发 COST_NAN; 6.0 更稳 -->
    <!-- 修复 E: 6.0 时尾段 ~2m 不可见 → 缩到 4.5 让 finelyCheck 全段校验更稳 -->
    <arg name="planning_horizon" value="5.0" />

    <!-- 1: use 2D Nav Goal to select goal  -->
    <!-- 2: use global waypoints below  -->
    <arg name="flight_type" value="1" />
    
    <!-- global waypoints -->
    <!-- It generates a piecewise min-snap traj passing all waypoints -->
    <arg name="point_num" value="7" />

    <arg name="point0_x" value="-9.0" />
    <arg name="point0_y" value="16.0" />
    <arg name="point0_z" value="0.0" />

    <arg name="point1_x" value="-1.0" />
    <arg name="point1_y" value="7.0" />
    <arg name="point1_z" value="0.0" />

    <arg name="point2_x" value="-4.0" />
    <arg name="point2_y" value="-3.0" />
    <arg name="point2_z" value="0.0" />

    <arg name="point3_x" value="2.0" />
    <arg name="point3_y" value="-9.0" />
    <arg name="point3_z" value="0.0" />

    <arg name="point4_x" value="-15.0" />
    <arg name="point4_y" value="-7.0" />
    <arg name="point4_z" value="0.0" />

    <arg name="point5_x" value="-10.0" />
    <arg name="point5_y" value="-0.7" />
    <arg name="point5_z" value="0.0" />

    <arg name="point6_x" value="-20.0" />
    <arg name="point6_y" value="5.0" />
    <arg name="point6_z" value="0.0" />


    
  </include>


  <node if="$(arg use_rqt_robot_steering)" pkg="rqt_robot_steering" type="rqt_robot_steering" name="rqt_robot_steering" output="screen">
    <param name="default_topic" value="/cmd_vel" />
  </node>
  
  <!-- trajectory server -->

  <node pkg="ego_planner" name="traj_server" type="traj_server" output="screen">
    <remap from="/position_cmd" to="planning/pos_cmd"/>
    <remap from="/odom_world" to="$(arg odom_topic)"/>
  </node>

  <rosparam command="load" file="$(find patchwork)/config/params_ouster128.yaml" />

  <node name="$(anon offline_own_data)" pkg="patchwork" type="offline_own_data" output="screen">
  <rosparam param="/algorithm">"patchwork"</rosparam> 
  <remap from="/pointcloud_scan" to="$(arg pointcloud_topic)"/>
  </node>

  <include file="$(find ego_planner)/launch/rviz.launch"/>




</launch>
